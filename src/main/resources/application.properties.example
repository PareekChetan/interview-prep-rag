# ===== Database connection =====
# Copy this file to application.properties and fill in your own values.
# Never commit application.properties itself - it's excluded via .gitignore.
spring.datasource.url=jdbc:postgresql://YOUR_SUPABASE_POOLER_HOST:5432/postgres
spring.datasource.username=postgres.YOUR_PROJECT_REF
spring.datasource.password=YOUR_DATABASE_PASSWORD

spring.jpa.hibernate.ddl-auto=none
spring.sql.init.mode=always

# ===== Embedding provider =====
# "mock" = free, local, fake-but-consistent vectors - no API key needed
# "huggingface" = real embeddings via Hugging Face's Inference Providers
embedding.provider=mock
embedding.huggingface.api-key=YOUR_HUGGINGFACE_TOKEN
embedding.dimension=384

server.port=8080
